<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- Registry privé GitLab -->
    <add key="CustomVaultPackage" value="https://gitlab.com/api/v4/projects/75607829/packages/nuget/index.json" />
    <add key="NodatimePackage" value="https://gitlab.com/api/v4/projects/75607901/packages/nuget/index.json"/>
    <!-- Registry public NuGet.org -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>

  <packageSourceMapping>
    <!-- Tous les packages proviennent de GitLab -->
    <packageSource key="CustomVaultPackage">
      <package pattern="CustomVaultPackage*" />
    </packageSource>
    <!-- Tout le reste ira sur NuGet.org -->
    <packageSource key="NodatimePackage">
      <package pattern="NodatimePackage*" />
    </packageSource>
     <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>

