      <add key="ClearTextPassword" value="glpat-b1q3ooX2Z4ahbJKcMPr_nG86MQp1OmY4ZDQ4Cw.01.121ob3fz1" />
    </NodatimePackage>
  </packageSourceCredentials>
</configuration>
